# GA4 — replace with real Measurement ID from Google Analytics
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# SMTP — for booking email notifications
# Leave blank in local dev; bookings will still be logged to console
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=yourpassword

# Override booking notification recipient (defaults to pampaetza.asenow1@gmail.com)
BOOKING_EMAIL_TO=pampaetza.asenow1@gmail.com
